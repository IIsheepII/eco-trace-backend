NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eco_trace?schema=public
ACCESS_TOKEN_SECRET=replace-access-secret
REFRESH_TOKEN_SECRET=replace-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_DOMAIN=
CORS_ORIGIN=http://localhost:3001
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
OCR_LANGUAGE=spa+eng
OCR_ENGINE=tesseract
OCR_MAX_FILE_SIZE_MB=10
OCR_TEMP_DIR=./tmp/ocr
OCR_CLEAN_TEMP_FILES=true
POPPLER_PATH=
PDF_CONVERSION_DPI=200
PDF_CONVERSION_FORMAT=png
PDF_MAX_PAGES=20
