NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eco_trace?schema=public
ACCESS_TOKEN_SECRET=replace-access-secret
REFRESH_TOKEN_SECRET=replace-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_DOMAIN=
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
OCR_LANGUAGE=spa+eng
OCR_ENGINE=tesseract
OCR_FALLBACK_ENGINE=tesseract
OCR_MAX_FILE_SIZE_MB=10
OCR_TEMP_DIR=./tmp/ocr
OCR_CLEAN_TEMP_FILES=true
OCR_TESSERACT_OEM=1
OCR_TESSERACT_PSM=6
OCR_TESSERACT_EXTRA_PSMS=11
TESSERACT_PATH=
POPPLER_PATH=
PDF_CONVERSION_DPI=300
PDF_CONVERSION_FORMAT=png
PDF_MAX_PAGES=20
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_VISION_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_VISION_TIMEOUT_MS=30000
